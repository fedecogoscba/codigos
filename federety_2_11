  digitalWrite(RELAY_DRIVER_PIN, HIGH);  // HIGH = caldera ENCENDIDA
  releOn = false;
  automatico = false;
  setpointTemp = NAN;

  // NUEVO: Inicializar modo AHORRO al arranque
  modoAhorro = true;
  ahorroEncendido = true;
  ahorroEncendidoHasta = millis() + AHORRO_ENCENDIDO_MS;
  ahorroApagadoHasta = 0;

  // NVS
  prefs.begin("tg", false);
  lastUpdateId = prefs.getInt("lastId", 0);

  // WiFi
  WiFi.begin(ssid, password);
  Serial.print("Conectando WiFi...");
  unsigned long startAttemptTime = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - startAttemptTime < 10000) {
    delay(250);
    Serial.print(".");
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✓ WiFi OK");
    digitalWrite(LED_WIFI, HIGH);
    wifiWasConnected = true;
  } else {
    Serial.println("\n⚠️ WiFi error");
    digitalWrite(LED_WIFI, LOW);
    wifiWasConnected = false;
  }
  
// Sensores
sensors.begin();
delay(50);

// Detección DS18B20
if (oneWireMutex != NULL && xSemaphoreTake(oneWireMutex, pdMS_TO_TICKS(1000))) {
  ds18b20Count = sensors.getDeviceCount();
  
  Serial.print("📋 DS18B20 encontrados: ");
  Serial.println(ds18b20Count);
  
  if (ds18b20Count > 0) {
    ds18b20Detectado = true;
    Serial.println("✓ Usando sensor índice 0");
  } else {
    ds18b20Detectado = false;
    Serial.println("✗ Ningún DS18B20 detectado");
  }
  
  // ✅ PRIMERA LECTURA (descartar - siempre inválida)
  delay(1000);
  sensors.requestTemperatures();
  delay(1000);
  delay(1000);
  float tempDescartada = sensors.getTempCByIndex(0);
  Serial.print("⚠️ Primera lectura descartada: ");
  Serial.println(tempDescartada);
  
  // ✅ SEGUNDA LECTURA (válida)
  delay(500);
  sensors.requestTemperatures();
  delay(1000);
  ds18b20Temp = sensors.getTempCByIndex(0);
  
  if (ds18b20Detectado) {
    if (isnan(ds18b20Temp) || ds18b20Temp == DEVICE_DISCONNECTED_C || ds18b20Temp == 85.0) {
      dsFaultCount++;
      ds18b20Temp = NAN;
      Serial.println("⚠️ DS18B20: Error en lectura inicial");
    } else {
      dsFaultCount = 0;
      Serial.print("✓ DS18B20 inicial (válida): ");
      Serial.print(ds18b20Temp, 1);
      Serial.println(" °C");
    }
  }
  
  xSemaphoreGive(oneWireMutex);
}

  // Termocupla
  termocoupleTemp = thermocouple.readCelsius();
  if (isnan(termocoupleTemp)) {
    thermoFaultCount++;
    Serial.println("⚠️ MAX6675: Error inicial");
    sendTelegramMessage("⚠️ ERROR: Termocupla no responde");
    termocuplaDesconectadaAnterior = true;
    mensajeErrorTermocuplaEnviado = true;
  } else {
    thermoFaultCount = 0;
    Serial.print("✓ MAX6675 inicial: ");
    Serial.print(termocoupleTemp, 1);
    Serial.println(" °C");
    termocuplaDesconectadaAnterior = false;
    mensajeErrorTermocuplaEnviado = false;
  }

  // Estado piloto
  if (!isnan(termocoupleTemp) && termocoupleTemp > thresholdHigh) {
    pilotoApagado = false;
    digitalWrite(LED_PILOTO_ENCENDIDO, HIGH);
    digitalWrite(LED_PILOTO_APAGADO, LOW);
  } else {
    pilotoApagado = true;
    digitalWrite(LED_PILOTO_ENCENDIDO, LOW);
    digitalWrite(LED_PILOTO_APAGADO, HIGH);
  }
  ultimoEstadoPiloto = pilotoApagado;

  // Mensaje inicio
  if (WiFi.status() == WL_CONNECTED) {
    char startupMsg[160];
    char ds18Msg[40];
    char tcMsg[40];

    if (!ds18b20Detectado || dsFaultCount >= FAULT_THRESHOLD || isnan(ds18b20Temp)) {
      snprintf(ds18Msg, sizeof(ds18Msg), "🌡️ DS18B20: ERROR");
    } else {
      snprintf(ds18Msg, sizeof(ds18Msg), "🌡️ Temp: %.1f °C", ds18b20Temp);
    }

    if (thermoFaultCount >= FAULT_THRESHOLD || isnan(termocoupleTemp)) {
      snprintf(tcMsg, sizeof(tcMsg), "🔥 Termocupla: ERROR");
    } else {
      snprintf(tcMsg, sizeof(tcMsg), "🔥 Termocupla: OK");
    }

    snprintf(startupMsg, sizeof(startupMsg), "%s\n%s\n%s",
      pilotoApagado ? "⚠️ Piloto: APAGADO" : "✅ Piloto: ENCENDIDO",
      ds18Msg, tcMsg);

    if (millis() - lastMsgSentMillis > MSG_MIN_INTERVAL_MS) {
      sendTelegramMessage(startupMsg);
      lastMsgSentMillis = millis();
    }
    delay(200);
  }

  // MODIFICADO: Aviso inicial con MODO AHORRO
  char estadoPiloto[32];
  char estadoTemp[48];
  char estadoRele[128];
  char mensaje[192];

  strcpy(estadoPiloto, pilotoApagado ? "⚠️ Piloto APAGADO" : "✅ Piloto ENCENDIDO");
  if (!ds18b20Detectado || dsFaultCount >= FAULT_THRESHOLD || isnan(ds18b20Temp)) {
    strcpy(estadoTemp, "🌡️ DS18B20: ERROR");
    strcpy(estadoRele, "Relé: ON (caldera encendida)\nModo: AHORRO\nSetpoint: No definido. Envíe /set XX.X");
  } else {
    snprintf(estadoTemp, sizeof(estadoTemp), "🌡️ Temp: %.1f °C", ds18b20Temp);
    snprintf(estadoRele, sizeof(estadoRele),
      "Relé: ON (caldera encendida)\nModo: AHORRO\nSetpoint: No definido. Envíe /set XX.X");
  }
  snprintf(mensaje, sizeof(mensaje), "📡 Inicio del sistema\n%s\n%s\n%s", estadoPiloto, estadoTemp, estadoRele);
  sendTelegramMessage(mensaje);

  // Tareas
  xTaskCreate(tareaDS18B20, "TareaDS18B20", 8192, NULL, 1, &handleDS18B20);
  xTaskCreate(tareaMAX6675, "TareaMAX6675", 2048, NULL, 1, NULL);
}

void loop() {
  unsigned long now = millis();

  checkWiFiAndNotify();

  bool termocuplaDesconectada = (thermoFaultCount >= FAULT_THRESHOLD);

  if (termocuplaDesconectada && !termocuplaDesconectadaAnterior && !mensajeErrorTermocuplaEnviado) {
    sendTelegramMessage("⚠️ ERROR: Termocupla no responde");
    mensajeErrorTermocuplaEnviado = true;
  }

  if (!termocuplaDesconectada && termocuplaDesconectadaAnterior && !isnan(termocoupleTemp)) {
    sendTelegramMessage("✅ Termocupla conectada");
    mensajeErrorTermocuplaEnviado = false;
  }

  termocuplaDesconectadaAnterior = termocuplaDesconectada;

  bool pilotCurrentlyOn = false;
  
  if (!isnan(termocoupleTemp) && thermoFaultCount < FAULT_THRESHOLD) {
    if (termocoupleTemp > thresholdHigh) {
      pilotCurrentlyOn = true;
    } else if (termocoupleTemp < thresholdLow) {
      pilotCurrentlyOn = false;
    } else {
      pilotCurrentlyOn = !pilotoApagado;
    }
  } else {
    pilotCurrentlyOn = false;
  }

  static bool prevPilotoApagadoInitialized = false;
  static bool prevPilotoApagado = false;
  if (!prevPilotoApagadoInitialized) {
    prevPilotoApagado = pilotoApagado;
    prevPilotoApagadoInitialized = true;
  }

  if (pilotCurrentlyOn && pilotoApagado) {
    pilotoApagado = false;
    digitalWrite(LED_PILOTO_ENCENDIDO, HIGH);
    digitalWrite(LED_PILOTO_APAGADO, LOW);
    Serial.println("Evento: PILOTO ENCENDIDO");
  }
  else if (!pilotCurrentlyOn && !pilotoApagado) {
    pilotoApagado = true;
    digitalWrite(LED_PILOTO_ENCENDIDO, LOW);
    digitalWrite(LED_PILOTO_APAGADO, HIGH);
    Serial.println("Evento: PILOTO APAGADO");
  }

  if (pilotoApagado != ultimoEstadoPiloto) {
    if (now - lastMsgSentMillis > MSG_MIN_INTERVAL_MS) {
      char estadoPiloto[32];
      char estadoTemp[48];
      char msgText[128];
      strcpy(estadoPiloto, pilotoApagado ? "⚠️ Piloto APAGADO" : "✅ Piloto ENCENDIDO");
      if (!ds18b20Detectado || dsFaultCount >= FAULT_THRESHOLD || isnan(ds18b20Temp)) {
        strcpy(estadoTemp, "🌡️ DS18B20: ERROR");
      } else {
        snprintf(estadoTemp, sizeof(estadoTemp), "🌡️ Temp: %.1f °C", ds18b20Temp);
      }
      snprintf(msgText, sizeof(msgText), "🔄 Cambio de estado:\n%s\n%s", estadoPiloto, estadoTemp);
      sendTelegramMessage(msgText);

      lastMsgSentMillis = now;
      ultimoEstadoPiloto = pilotoApagado;
    }
  }

  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(LED_WIFI, HIGH);
  } else {
    digitalWrite(LED_WIFI, LOW);
  }

   static bool mensajeErrorDS18B20Enviado = false;

   // ✅ DETECCIÓN RÁPIDA DE ERROR - Sin esperar al dsFaultCount
  if (isnan(ds18b20Temp) && !mensajeErrorDS18B20Enviado) {
    unsigned long ahora = millis();
    
    // Si hay comando manual RECIENTE, SOLO notifica, NO actives AHORRO
    if ((ahora - ultimoComandoManual) < 10000) {
      sendTelegramMessage("⚠️ ERROR: DS18B20 no responde, MODO AHORRO.");
      mensajeErrorDS18B20Enviado = true;
      return;  // ← SALE, no activa modoAhorro
    }

    // Si NO hay manual reciente, ACTIVA AHORRO
    sendTelegramMessage("⚠️ ERROR: DS18B20 no responde, MODO AHORRO.");
    mensajeErrorDS18B20Enviado = true;
    modoAhorro = true;
    ahorroEncendido = true;
    ahorroEncendidoHasta = millis() + AHORRO_ENCENDIDO_MS;
    automatico = false;
    setpointTemp = NAN;
    releOn = false;
    digitalWrite(RELAY_DRIVER_PIN, HIGH);
  }

  // ✅ RECUPERACIÓN
  if (!isnan(ds18b20Temp) && mensajeErrorDS18B20Enviado) {
    sendTelegramMessage("✅ DS18B20 reconectado");
    mensajeErrorDS18B20Enviado = false;
    dsFaultCount = 0;
    modoAhorro = false;
  }

  static unsigned long lastTelegramPollMillis = 0;
  if (now - lastTelegramPollMillis >= 1000) {
    lastTelegramPollMillis = now;
    checkTelegramMessages();
  }


  // NUEVO: LÓGICA DE CONTROL MODO AHORRO
  if (modoAhorro) {
    if (ahorroEncendido) {
      // Fase ENCENDIDA (5 minutos)
      if (now >= ahorroEncendidoHasta) {
        // Cambiar a fase APAGADA
        ahorroEncendido = false;
        ahorroApagadoHasta = millis() + AHORRO_APAGADO_MS;
        releOn = true;
        digitalWrite(RELAY_DRIVER_PIN, LOW);  // Caldera OFF
        Serial.println("🟡 AHORRO: Cambiando a fase APAGADA (2 horas)");
        sendTelegramMessage("🟡 MODO AHORRO: Caldera APAGADA por 2 horas");
      } else {
        // Mantener caldera ENCENDIDA
        releOn = false;
        digitalWrite(RELAY_DRIVER_PIN, HIGH);
      }
    } else {
      // Fase APAGADA (2 horas)
      if (now >= ahorroApagadoHasta) {
        // Cambiar a fase ENCENDIDA
        ahorroEncendido = true;
        ahorroEncendidoHasta = millis() + AHORRO_ENCENDIDO_MS;
        releOn = false;
        digitalWrite(RELAY_DRIVER_PIN, HIGH);  // Caldera ON
        Serial.println("🔥 AHORRO: Cambiando a fase ENCENDIDA (5 minutos)");
        sendTelegramMessage("🔥 MODO AHORRO: Caldera ENCENDIDA por 5 minutos");
      } else {
        // Mantener caldera APAGADA
        releOn = true;
        digitalWrite(RELAY_DRIVER_PIN, LOW);
      }
    }
  }


  // ✅ CONTROL DEL RELÉ - PROTEGIDO DE SOBRESCRITURAS MANUALES
  // Solo controlar si NO hay un comando manual reciente Y NO está en AHORRO
  // if ((now - ultimoComandoManual) > PROTECCION_MANUAL_MS && !modoAhorro) {
    controlarReleAutomatico();
  // }

  delay(10);
}

void checkWiFiAndNotify() {
  unsigned long now = millis();
  if (now - lastWiFiCheck > WIFI_CHECK_INTERVAL) {
    lastWiFiCheck = now;
    if (WiFi.status() != WL_CONNECTED) {
      if (handleDS18B20 != NULL) vTaskSuspend(handleDS18B20);
      if (!wifiWasConnected) {
        if (wifiLostSince == 0) wifiLostSince = now;
        if ((now - wifiLostSince > WIFI_MANUAL_TIMEOUT) && !modoManualPorWiFi) {
          // MODIFICADO: Activar AHORRO en lugar de MANUAL
          modoAhorro = true;
          ahorroEncendido = true;
          ahorroEncendidoHasta = millis() + AHORRO_ENCENDIDO_MS;
          ahorroApagadoHasta = 0;
          automatico = false;
          setpointTemp = NAN;
          releOn = false;
          digitalWrite(RELAY_DRIVER_PIN, HIGH);
          modoManualPorWiFi = true;
          sendTelegramMessage("⚠️ WiFi perdido > 2 min - MODO AHORRO activado.");
        }
      } else {
        wifiLostSince = now;
        wifiWasConnected = false;
      }
      WiFi.reconnect();
    } else {
      if (!wifiWasConnected) {
        sendTelegramMessage("✅ WiFi reconectado");
        if (oneWireMutex != NULL && xSemaphoreTake(oneWireMutex, pdMS_TO_TICKS(1000))) {
          oneWire.reset();
          sensors.begin();
          delay(100);
          sensors.requestTemperatures();
          ds18b20Temp = sensors.getTempCByIndex(0);
          xSemaphoreGive(oneWireMutex);
        }
        if (handleDS18B20 != NULL) vTaskResume(handleDS18B20);
        
        if (modoManualPorWiFi) {
          sendTelegramMessage("ℹ️ Sistema en MODO AHORRO. Envíe /set XX.X para automático");
          modoManualPorWiFi = false;
          modoAhorro = false;  // Salir de AHORRO al reconectar
        }
        wifiLostSince = 0;
        wifiWasConnected = true;
      }
    }
  }
}

// ✅ CONTROL AUTOMÁTICO - NO INTERFIERE CON MANUALES
void controlarReleAutomatico() {
   unsigned long now = millis();

// ✅ PROTECCIÓN: Si hay comando manual reciente, NO hagas nada
  if ((now - ultimoComandoManual) < 10000) {
    return;  // ← Sal de la función, no toques el relé
  }
  
  // Si hay error DS18B20, forzar ON
  // if (!ds18b20Detectado || dsFaultCount >= FAULT_THRESHOLD || isnan(ds18b20Temp)) {
   // releOn = false;
   // digitalWrite(RELAY_DRIVER_PIN, HIGH);
  //  return;
 // }
   
  // Si NO estamos en automático, respetar el estado manual
  if (!automatico) {
    if (releOn) {
      digitalWrite(RELAY_DRIVER_PIN, LOW);
    } else {
      digitalWrite(RELAY_DRIVER_PIN, HIGH);
    }
    return;
  }

  // AUTOMÁTICO: aplicar histéresis
  if (isnan(setpointTemp)) {
    releOn = false;
    digitalWrite(RELAY_DRIVER_PIN, HIGH);
    return;
  }

  if (ds18b20Temp < setpointTemp - histeresis) {
    releOn = false;
    digitalWrite(RELAY_DRIVER_PIN, HIGH);
  } else if (ds18b20Temp > setpointTemp + histeresis) {
    releOn = true;
    digitalWrite(RELAY_DRIVER_PIN, LOW);
  }
}

void checkTelegramMessages() {
  if (WiFi.status() != WL_CONNECTED) return;
  HTTPClient http;
  String url = "https://api.telegram.org/bot" + String(botToken) +
               "/getUpdates?offset=" + String(lastUpdateId + 1) + "&limit=1";
  http.begin(url);
  int code = http.GET();

  if (code > 0) {
    String resp = http.getString();

    const size_t capacity = 2048;
    DynamicJsonDocument doc(capacity);
    DeserializationError error = deserializeJson(doc, resp);

    if (error) {
      http.end();
      return;
    }

    JsonArray result = doc["result"];
    if (result.size() == 0) {
      http.end();
      return;
    }

    JsonObject msgObj = result[0];
    int32_t updId = msgObj["update_id"];
    JsonObject message = msgObj["message"];
    int64_t incomingChatId = message["chat"]["id"].as<int64_t>();
    const char* msgText = message["text"];

    if (!msgText) {
      http.end();
      return;
    }

    int64_t allowedChat = atoll(chatID);

    if (incomingChatId != allowedChat) {
      http.end();
      return;
    }

    lastUpdateId = updId;
    prefs.putInt("lastId", lastUpdateId);

    String msg = String(msgText);
    char respuesta[192];

    if (msg == "/estado") {
      char estadoPiloto[32];
      char estadoTemp[48];
      char estadoRele[128];

      if (thermoFaultCount >= FAULT_THRESHOLD || isnan(termocoupleTemp)) {
        strcpy(estadoPiloto, "⚠️ ERROR: Termocupla");
      } else {
        strcpy(estadoPiloto, pilotoApagado ? "⚠️ Piloto APAGADO" : "✅ Piloto ENCENDIDO");
      }

      if (!ds18b20Detectado || dsFaultCount >= FAULT_THRESHOLD || isnan(ds18b20Temp)) {
        strcpy(estadoTemp, "🌡️ DS18B20: ERROR");
        if (modoAhorro) {
          strcpy(estadoRele, "Relé: Según AHORRO\nModo: AHORRO");
        } else {
          snprintf(estadoRele, sizeof(estadoRele), "Relé: %s\nModo: Manual", 
            releOn ? "OFF" : "ON");  // ← Ahora lee releOn
        }
      } else if (!automatico || isnan(setpointTemp)) {
        snprintf(estadoTemp, sizeof(estadoTemp), "🌡️ Temp: %.1f °C", ds18b20Temp);
        if (modoAhorro) {
          snprintf(estadoRele, sizeof(estadoRele), "Relé: %s (según AHORRO)\nModo: AHORRO",
            ahorroEncendido ? "ON" : "OFF");
        } else {
          snprintf(estadoRele, sizeof(estadoRele), "Relé: %s\nModo: Manual", 
            releOn ? "OFF" : "ON");
        }
      } else {
        snprintf(estadoTemp, sizeof(estadoTemp), "🌡️ Temp: %.1f °C", ds18b20Temp);
        snprintf(estadoRele, sizeof(estadoRele),
          "Relé: %s\nModo: Automático\nSetpoint: %.1f °C",
          releOn ? "OFF" : "ON",
          setpointTemp
        );
      }
      snprintf(respuesta, sizeof(respuesta), "%s\n%s\n%s", estadoPiloto, estadoTemp, estadoRele);
      sendTelegramMessage(respuesta);
    } 
    
    else if (msg.startsWith("/set ")) {
      float valor = msg.substring(5).toFloat();
      if (!ds18b20Detectado || dsFaultCount >= FAULT_THRESHOLD || isnan(ds18b20Temp)) {
        // MODIFICADO: Mensaje menciona AHORRO
        sendTelegramMessage("❌ DS18B20 error - Activando MODO AHORRO");
        modoAhorro = true;
        ahorroEncendido = true;
        ahorroEncendidoHasta = millis() + AHORRO_ENCENDIDO_MS;
        ahorroApagadoHasta = 0;
        automatico = false;
        setpointTemp = NAN;
        releOn = false;
        digitalWrite(RELAY_DRIVER_PIN, HIGH);
      } else if (valor >= 10.0 && valor <= 35.0) {
        setpointTemp = valor;
        automatico = true;
        modoAhorro = false;  // Salir de AHORRO al activar automático
        controlarReleAutomatico();
        snprintf(respuesta, sizeof(respuesta),
          "✅ Setpoint: %.1f °C\nModo: Automático\nRelé: %s",
          setpointTemp,
          releOn ? "OFF" : "ON");
        sendTelegramMessage(respuesta);
      } else {
        sendTelegramMessage("❌ Valor fuera de rango (10-35°C)");
      }
    }

    // ✅ COMANDO /rele_off - SIEMPRE ACTIVO
    else if (msg == "/rele_off") {
      ultimoComandoManual = millis() + 10000;  // ← 10 segundos
      modoAhorro = false;
      automatico = false;
      setpointTemp = NAN;
      releOn = true;
      digitalWrite(RELAY_DRIVER_PIN, LOW);
      Serial.println("✓ /rele_off ejecutado");
      sendTelegramMessage("⚪ Relé OFF - Caldera apagada (Manual)");
    }
    
    // ✅ COMANDO /rele_on - SIEMPRE ACTIVO
    else if (msg == "/rele_on") {
      ultimoComandoManual = millis() + 10000;  // ← 10 segundos
      modoAhorro = false;
      automatico = false;
      setpointTemp = NAN;
      releOn = false;
      digitalWrite(RELAY_DRIVER_PIN, HIGH);
      Serial.println("✓ /rele_on ejecutado");
      sendTelegramMessage("⚫ Relé ON - Caldera encendida (Manual)");
    }
    
    else if (msg == "/termocupla") {
      if (thermoFaultCount >= FAULT_THRESHOLD) {
        sendTelegramMessage("⚠️ Termocupla: ERROR");
      } else {
        snprintf(respuesta, sizeof(respuesta), "🔥 Termocupla: %.1f °C", termocoupleTemp);
        sendTelegramMessage(respuesta);
      }
    } 
    
    else if (msg == "/reiniciar") {
      snprintf(respuesta, sizeof(respuesta), "♻️ Reiniciando ESP32...\n");
      char pilotoMsg[48];
      char tempMsg[48];
      char modoMsg[48];
      
      if (thermoFaultCount >= FAULT_THRESHOLD || isnan(termocoupleTemp)) {
        snprintf(pilotoMsg, sizeof(pilotoMsg), "⚠️ Termocupla: ERROR");
      } else {
        snprintf(pilotoMsg, sizeof(pilotoMsg), pilotoApagado ? "⚠️ Piloto APAGADO" : "✅ Piloto ENCENDIDO");
      }
      
      if (!ds18b20Detectado || dsFaultCount >= FAULT_THRESHOLD || isnan(ds18b20Temp)) {
        snprintf(tempMsg, sizeof(tempMsg), "🌡️ DS18B20: ERROR");
      } else {
        snprintf(tempMsg, sizeof(tempMsg), "🌡️ Temp: %.1f °C", ds18b20Temp);
      }
      
      if (modoAhorro) {
        snprintf(modoMsg, sizeof(modoMsg), "Modo: AHORRO");
      } else if (automatico) {
        snprintf(modoMsg, sizeof(modoMsg), "Modo: Automático");
      } else {
        snprintf(modoMsg, sizeof(modoMsg), "Modo: Manual");
      }
      
      strncat(respuesta, pilotoMsg, sizeof(respuesta) - strlen(respuesta) - 1);
      strncat(respuesta, "\n", sizeof(respuesta) - strlen(respuesta) - 1);
      strncat(respuesta, tempMsg, sizeof(respuesta) - strlen(respuesta) - 1);
      strncat(respuesta, "\n", sizeof(respuesta) - strlen(respuesta) - 1);
      strncat(respuesta, modoMsg, sizeof(respuesta) - strlen(respuesta) - 1);
      sendTelegramMessage(respuesta);
      delay(1000);
      ESP.restart();
    }
    
    else {
      sendTelegramMessage("❓ Comando desconocido.\n/estado, /set XX.X, /rele_off, /rele_on, /termocupla, /reiniciar");
    }
  }
  http.end();
}
