  pinMode(LED_PILOTO_ENCENDIDO, OUTPUT);
  digitalWrite(LED_PILOTO_ENCENDIDO, LOW);
  pinMode(LED_WIFI, OUTPUT);
  digitalWrite(LED_WIFI, LOW);

  // Relé - ESTADO INICIAL: ENCENDIDO (caldera ON)
